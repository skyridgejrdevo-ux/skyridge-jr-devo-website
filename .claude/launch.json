{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "skyridge-site",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path'),port=process.env.PORT||8788;h.createServer((q,r)=>{const url=decodeURIComponent(q.url.split('?')[0]);let f=p.join('/Users/brandonsmith/Repos/skyridge-jr-devo-website',url==='/'?'/index.html':url);const ext=p.extname(f);const ct={'.css':'text/css','.js':'text/javascript','.png':'image/png','.jpg':'image/jpeg','.jpeg':'image/jpeg','.svg':'image/svg+xml'}[ext]||'text/html';fs.access(f,e=>{if(e){r.writeHead(404);r.end('Not found');return}r.writeHead(200,{'Content-Type':ct});fs.createReadStream(f).pipe(r)})}).listen(port)"],
      "port": 8788,
      "autoPort": true
    }
  ]
}
